<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> - Comunication_LTD</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <main class="container auth-container">
      <h1>Forgot Password</h1>
      <div class="mode-toggle">
        <p class="mode-note">
          Current mode:
          <strong class="mode-label <%= appMode === 'secure' ? 'mode-secure' : 'mode-vulnerable' %>">
            <%= appMode %>
          </strong>
        </p>
        <span
          class="mode-info"
          data-tooltip="<%= appMode === 'secure' ? 'Uses parameterized SQL and escapes output.' : 'Uses string-built SQL and renders raw output.' %>"
          aria-label="Mode info"
        >
          i
        </span>
        <form method="post" action="/app-mode" class="mode-toggle-form">
          <input
            type="hidden"
            name="appMode"
            value="<%= appMode === 'secure' ? 'vulnerable' : 'secure' %>"
          />
          <button type="submit" class="button-outline">Change Mode</button>
        </form>
      </div>

      <% if (flashError) { %>
      <div class="alert alert-error"><%= flashError %></div>
      <% } %>
      <% if (flashSuccess) { %>
      <div class="alert alert-success"><%= flashSuccess %></div>
      <% } %>

      <form method="post" action="/forgot-password" class="card form-grid">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required />

        <button type="submit">Send Recovery Token</button>
      </form>

      <nav class="links-row">
        <a href="/login">Back to login</a>
      </nav>
    </main>
  </body>
</html>
