<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> - Comunication_LTD</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <main class="container dashboard-container">
      <header class="dashboard-header">
        <div>
          <h1>Customer Management Dashboard</h1>
          <p>
            Signed in as <strong><%= currentUser.username %></strong> | Mode:
            <strong class="mode-label <%= appMode === 'secure' ? 'mode-secure' : 'mode-vulnerable' %>">
              <%= appMode %>
            </strong>
            <span
              class="mode-info"
              data-tooltip="<%= appMode === 'secure' ? 'Uses parameterized SQL and escapes output.' : 'Uses string-built SQL and renders raw output.' %>"
              aria-label="Mode info"
            >
              i
            </span>
          </p>
        </div>
        <div class="header-actions">
          <a href="/change-password" class="button-link">Change Password</a>
          <form method="post" action="/logout">
            <button type="submit" class="button-danger">Logout</button>
          </form>
        </div>
      </header>

      <p class="mode-warning">
        Mode switching exists only for learning and project demonstration simplicity.
      </p>

      <% if (flashError) { %>
      <div class="alert alert-error"><%= flashError %></div>
      <% } %>
      <section class="card">
        <h2>Add Customer</h2>
        <form method="post" action="/customers" class="form-grid two-col">
          <div>
            <label for="customerName">Customer Name</label>
            <input id="customerName" name="customerName" type="text" required />
          </div>
          <div>
            <label for="sector">Sector</label>
            <input id="sector" name="sector" type="text" required />
          </div>
          <button type="submit">Add Customer</button>
        </form>
      </section>

      <section class="card">
        <h2>Customers</h2>

        <% if (!customers || customers.length === 0) { %>
        <p>No customers yet.</p>
        <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Sector</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% customers.forEach((customer) => { %>
            <tr>
              <td>
                <% if (appMode === 'vulnerable') { %>
                <%- customer.customer_name %>
                <% } else { %>
                <%= customer.customer_name %>
                <% } %>
              </td>
              <td><%= customer.sector %></td>
              <td><%= new Date(customer.created_at).toLocaleString() %></td>
              <td>
                <form method="post" action="/customers/<%= customer.id %>/delete">
                  <button type="submit" class="button-danger button-small">Remove</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </section>
    </main>
  </body>
</html>
