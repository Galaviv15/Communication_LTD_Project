{
  "password_policy": {
    "min_length": 10,
    "require_uppercase": true,
    "require_lowercase": true,
    "require_numbers": true,
    "require_special_chars": true,
    "min_complexity_categories": 3, 
    "history_limit": 3,
    "blocked_keywords": ["admin", "123456", "I AM ADMIN", "password"]
  },
  "lockout_policy": {
    "max_attempts": 3,
    "lockout_duration_minutes": 30
  },
  "security_keys": {
    "hmac_secret": "YOUR_SERVER_SECRET_KEY"
  }
}